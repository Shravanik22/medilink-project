# ─── MediLink Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# On Render, set these directly in the Environment Variables section.

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_string

# Set to 'true' ONLY for local development. ALWAYS 'false' on Render/production.
FLASK_DEBUG=false

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=medilink

# ── File Uploads ─────────────────────────────────────────────────────────────
# Defaults to ./uploads relative to app.py. Override if needed.
# UPLOAD_FOLDER=/path/to/uploads

# ── OCR / Tesseract (optional) ───────────────────────────────────────────────
# Only needed on Windows if tesseract.exe is not on system PATH.
# On Linux/Render, install via buildpack or apt. App works without it.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Server Port ──────────────────────────────────────────────────────────────
# Render sets PORT automatically. Leave commented out unless overriding.
# PORT=5000

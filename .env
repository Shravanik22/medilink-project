# ─── MediLink Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# On Render, set these directly in the "Environment Variables" section of your service.
# NEVER commit a real .env file to Git.

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate a strong random secret locally:
#   python -c "import secrets; print(secrets.token_hex(32))"
# On Render, use "Generate Value" in the env vars panel.
SECRET_KEY=change_this_to_a_long_random_string

# Set to 'true' ONLY for local development. ALWAYS 'false' on Render/production.
FLASK_DEBUG=false

# ── Database (MySQL / PlanetScale / Railway / Aiven / TiDB Cloud) ────────────
# Replace with your cloud MySQL provider's connection details.
DB_HOST=your-mysql-host.example.com
DB_USER=root
DB_PASSWORD=@Shravani123
DB_NAME=medilink

# ── Render / Cloud Notes ─────────────────────────────────────────────────────
# Render free-tier services spin down after 15 minutes of inactivity.
# Your first request after sleep will be slow (cold start ~30s). This is normal.
#
# For a "always-on" DB, use one of these free cloud MySQL services:
#   - PlanetScale  → https://planetscale.com  (free hobby plan)
#   - Railway      → https://railway.app       (free starter plan)
#   - Aiven        → https://aiven.io          (free trial)
#   - TiDB Cloud   → https://tidbcloud.com     (free serverless tier)
#
# After getting credentials, set the 4 DB_* vars in Render dashboard:
#   Dashboard → Your Service → Environment → Add Environment Variable

# ── File Uploads ─────────────────────────────────────────────────────────────
# Defaults to ./uploads relative to app.py. Override if needed.
# NOTE: Render's filesystem is ephemeral — uploads are lost on redeploy.
# For production, use a cloud storage service (e.g. Cloudinary, AWS S3).
# UPLOAD_FOLDER=/tmp/medilink_uploads

# ── OCR / Tesseract (optional) ───────────────────────────────────────────────
# Only needed on Windows if tesseract.exe is not on system PATH.
# On Linux/Render, install via: apt-get install tesseract-ocr
# App degrades gracefully without it (reports upload but metrics not extracted).
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── PORT ─────────────────────────────────────────────────────────────────────
# Render sets PORT automatically. Leave commented unless running locally on
# a specific port.
# PORT=5000
